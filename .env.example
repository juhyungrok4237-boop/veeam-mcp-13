# Veeam VBR MCP Server - Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Veeam Server Connection ────────────────────────────────────────────────
# URL scheme: https://<hostname-or-ip>
VEEAM_SERVER=https://192.168.1.100
VEEAM_PORT=9419
VEEAM_USERNAME=Administrator
VEEAM_PASSWORD=YourPasswordHere

# ─── TLS (SSL) ──────────────────────────────────────────────────────────────
# Set to 0 to bypass self-signed certificate errors (common in VBR lab environments)
NODE_TLS_REJECT_UNAUTHORIZED=0

# ─── MCP Transport Mode ─────────────────────────────────────────────────────
# "stdio"           : for Claude Desktop / local LLM clients
# "streamable-http" : for Dify / network-accessible HTTP server (MCP 2025-03-26)
MCP_TRANSPORT_MODE=streamable-http

# ─── HTTP Mode Settings (only used when MCP_TRANSPORT_MODE=streamable-http) ─
MCP_HTTP_PORT=3000

# Stateless mode: true  = no session state (recommended for Dify)
#                 false = stateful with session ID (default)
MCP_STATELESS=false

